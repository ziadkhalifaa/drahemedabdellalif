# Database (Supabase with PgBouncer)
DATABASE_URL="postgresql://postgres:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-string"

# API Server
PORT=4000
NODE_ENV=development
VERCEL=false
ALLOWED_ORIGINS="http://localhost:3000,https://drahmedabdellatif.com"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_WHATSAPP_NUMBER="+201234567890"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# WhatsApp (UltraMsg)
ULTRAMSG_INSTANCE="instanceXXXXXX"
ULTRAMSG_TOKEN="your-ultramsg-token"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Supabase Storage (for API - use service_role key for admin operations)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Daily.co Video API
DAILY_API_KEY="your-daily-api-key"

# Paymob Payment Gateway
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_INTEGRATION_ID="your-integration-id"
PAYMOB_IFRAME_ID="your-iframe-id"
PAYMOB_HMAC_SECRET="your-hmac-secret"
